# Copy to ".env" and tweak. docker compose (and run-extra.sh) read it automatically.

# Match your host user so bind-mounted files aren't root-owned.
#   id -u  /  id -g   (WSL/Linux). On Windows Docker Desktop, 1000 is usually fine.
UID=1000
GID=1000

# Shared by all instances (LOCAL ONLY -- servers bind to 127.0.0.1, not the world).
RCON_PASSWORD=changeme_local_only

# Map. WORLD_SIZE >= 2000 avoids "InsideTerrain" spawn kicks. For near-instant
# generation while testing, set SERVER_LEVEL=Barren.
MAX_PLAYERS=10
WORLD_SIZE=3000
SEED=1337
SERVER_LEVEL=Procedural Map

# NOTE: the game + mod (and the staging overlay) are baked into each image at
# BUILD time -- there are no update-on-start flags anymore. To refresh to newer
# game/mod builds, rebuild the image:
#   docker compose build --no-cache carbon-staging
#
# Staging overlay sources are build args (defaults live in the Dockerfile).
# Override per build if Carbon's asset name or Oxide's CI URL moves:
#   docker compose build --build-arg OXIDE_STAGING_URL=... oxide-staging

# NOTE: the map is pre-generated and baked into the image. Changing SEED,
# WORLD_SIZE, or SERVER_LEVEL means you must REBUILD for the baked map to
# match (otherwise the server regenerates on boot):
#   docker compose build <service>
